# Copy this file to `.env` on the server and fill in real values.
# NEVER commit .env to Git — only .env.example belongs in source control.

# ---- Application ----
APP_NAME="Devithor LMS"
APP_ENV=production           # production | local
APP_DEBUG=false              # true only in local dev
APP_URL=https://api.example.com
APP_TIMEZONE=UTC

# ---- Auth secret ----
# Used to sign mobile bearer tokens (HMAC-SHA256). Generate with:
#   openssl rand -base64 48
# Rotating this signs out every mobile user.
APP_KEY=replace-with-output-of-openssl-rand-base64-48

# ---- Database (Hostinger MySQL) ----
# In hPanel → Databases → MySQL Databases, create a DB + user, then paste here.
# Hostinger cloud DB hosts are typically `localhost` when the app + DB live on
# the same plan; the actual hostname may also look like `mysql.<panel-id>.hstgrcp.com`.
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=u123456789_lms
DB_USERNAME=u123456789_admin
DB_PASSWORD=set-a-strong-password-here
DB_CHARSET=utf8mb4

# ---- Admin bootstrap (first admin user, created by seed) ----
# After first deploy these are used by `php seeds/seed.php` to create your
# admin login. Change ADMIN_PASSWORD before seeding, then *delete these lines*
# from .env once you've logged in successfully.
ADMIN_EMAIL=admin@devithor.com
ADMIN_NAME="Site Admin"
ADMIN_PASSWORD=change-me-now-then-remove-from-env

# ---- CORS ----
# Comma-separated origins allowed to call the API. The Android app uses no
# Origin header so leave this empty unless you also build a web client.
CORS_ALLOWED_ORIGINS=

# ---- Logging ----
LOG_PATH=../storage/logs/app.log
LOG_LEVEL=info               # debug | info | warning | error
